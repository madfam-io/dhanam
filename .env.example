# =============================================================================
# DHANAM - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values
# DO NOT commit .env to version control
# =============================================================================

# -----------------------------------------------------------------------------
# SHARED INFRASTRUCTURE (MADFAM Ecosystem)
# -----------------------------------------------------------------------------
# Database - Using shared PostgreSQL
DATABASE_URL=postgresql://madfam:madfam_dev_password@madfam-postgres-shared:5432/dhanam_db

# Redis - Using shared Redis (DB 3 for Dhanam)
REDIS_URL=redis://:redis_dev_password@madfam-redis-shared:6379/3

# -----------------------------------------------------------------------------
# JANUA AUTHENTICATION
# -----------------------------------------------------------------------------
JANUA_ENABLED=true
JANUA_API_URL=http://janua-api:8001
JANUA_JWT_SECRET=dev-shared-janua-secret-32chars!!

# -----------------------------------------------------------------------------
# APPLICATION SETTINGS
# See PORT_REGISTRY.md in solarpunk-foundry for port assignments
# -----------------------------------------------------------------------------
NODE_ENV=development
WEB_PORT=3040
API_PORT=4010

# Next.js
NEXT_PUBLIC_API_URL=http://localhost:4010
NEXTAUTH_URL=http://localhost:3040
NEXTAUTH_SECRET=dev-nextauth-secret-change-in-production

# -----------------------------------------------------------------------------
# EXTERNAL SERVICES
# -----------------------------------------------------------------------------
# Email (MailHog for development)
SMTP_HOST=dhanam-mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@dhanam.local

# Banxico (FX rates)
BANXICO_API_TOKEN=__YOUR_BANXICO_API_TOKEN__

# -----------------------------------------------------------------------------
# FINANCIAL INTEGRATIONS (Mock keys for development)
# -----------------------------------------------------------------------------
# Belvo (Mexico banking)
BELVO_SECRET_KEY_ID=__YOUR_BELVO_SECRET_KEY_ID__
BELVO_SECRET_KEY_PASSWORD=__YOUR_BELVO_SECRET_KEY_PASSWORD__
BELVO_WEBHOOK_SECRET=__YOUR_BELVO_WEBHOOK_SECRET__
BELVO_ENV=sandbox

# Plaid (US banking)
PLAID_CLIENT_ID=__YOUR_PLAID_CLIENT_ID__
PLAID_SECRET=__YOUR_PLAID_SECRET__
PLAID_WEBHOOK_SECRET=__YOUR_PLAID_WEBHOOK_SECRET__
PLAID_ENV=sandbox

# Bitso (Crypto)
BITSO_API_KEY=__YOUR_BITSO_API_KEY__
BITSO_API_SECRET=__YOUR_BITSO_API_SECRET__

# Zapper (DeFi portfolio — optional)
ZAPPER_API_KEY=__YOUR_ZAPPER_API_KEY__

# -----------------------------------------------------------------------------
# BILLING (Hybrid Router: Stripe MX + Paddle Global)
# -----------------------------------------------------------------------------
# Janua Billing Integration
JANUA_BILLING_ENABLED=true
JANUA_API_KEY=__YOUR_JANUA_API_KEY__
JANUA_WEBHOOK_SECRET=__YOUR_JANUA_WEBHOOK_SECRET__
DHANAM_WEBHOOK_SECRET=__YOUR_DHANAM_WEBHOOK_SECRET__

# Stripe Mexico
STRIPE_MX_SECRET_KEY=__YOUR_STRIPE_MX_SECRET_KEY__
STRIPE_MX_PUBLISHABLE_KEY=__YOUR_STRIPE_MX_PUBLISHABLE_KEY__
STRIPE_MX_WEBHOOK_SECRET=__YOUR_STRIPE_MX_WEBHOOK_SECRET__
STRIPE_PREMIUM_PRICE_ID=price_xxxxx

# Paddle (Global)
PADDLE_VENDOR_ID=__YOUR_PADDLE_VENDOR_ID__
PADDLE_API_KEY=__YOUR_PADDLE_API_KEY__
PADDLE_CLIENT_TOKEN=__YOUR_PADDLE_CLIENT_TOKEN__
PADDLE_WEBHOOK_SECRET=__YOUR_PADDLE_WEBHOOK_SECRET__
PADDLE_ENVIRONMENT=sandbox

# -----------------------------------------------------------------------------
# MONITORING (Optional)
# -----------------------------------------------------------------------------
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
POSTHOG_API_KEY=
