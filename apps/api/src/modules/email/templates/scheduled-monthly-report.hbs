{{> header subject="Your Scheduled Monthly Financial Report"}}

<h2 style="margin: 0 0 20px; color: #1a73e8; font-size: 24px;">📈 Monthly Financial Report</h2>

<p style="margin: 0 0 20px;">Hi there,</p>

<p style="margin: 0 0 20px;">Your scheduled monthly financial report for <strong>{{spaceName}}</strong> is ready.</p>

<!-- Report Details -->
<div style="margin: 30px 0; padding: 20px; background-color: #e3f2fd; border-radius: 4px;">
  <h3 style="margin: 0 0 15px; color: #1976d2; font-size: 18px;">Report Details</h3>

  <table style="width: 100%; border-collapse: collapse;">
    <tr>
      <td style="padding: 8px 0; color: #666;">Report Type:</td>
      <td style="padding: 8px 0; text-align: right; font-weight: 600;">Monthly Summary</td>
    </tr>
    <tr>
      <td style="padding: 8px 0; color: #666;">Space:</td>
      <td style="padding: 8px 0; text-align: right; font-weight: 600;">{{spaceName}}</td>
    </tr>
    <tr>
      <td style="padding: 8px 0; color: #666;">Period:</td>
      <td style="padding: 8px 0; text-align: right; font-weight: 600;">{{startDate}} - {{endDate}}</td>
    </tr>
  </table>
</div>

{{#if attachment}}
<p style="margin: 30px 0; padding: 15px; background-color: #f5f5f5; border-radius: 4px;">
  📎 <strong>Attachment:</strong> Your detailed monthly report is attached to this email.
</p>
{{/if}}

{{> button text="View Full Analytics" url=(concat appUrl "/analytics")}}

<p style="margin: 30px 0 0; color: #666; font-size: 14px;">
  This report is generated on the 1st of each month. You can change your report preferences in your <a href="{{appUrl}}/settings/notifications" style="color: #1a73e8;">account settings</a>.
</p>

{{> footer}}